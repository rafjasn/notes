NODE_ENV=development
PORT=3000
JWT_SECRET=change-me-in-development
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_PROVIDER=keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=notes
KEYCLOAK_CLIENT_ID=notes-api
KEYCLOAK_ADMIN_CLIENT_ID=notes-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=CHANGE_ME_IN_ENV
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_HOSTED_UI_DOMAIN=

MONGO_URI=mongodb://mongo:27017/notes
MONGO_IMAGE=mongo:8.2
CORS_ORIGIN=http://localhost
FANOUT_CORS_ORIGIN=http://localhost
FRONTEND_URL=http://localhost

AWS_REGION=us-east-1
AWS_ENDPOINT=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:notes-events
SQS_QUEUE_URL=http://localstack:4566/000000000000/notes-events-queue
DYNAMODB_TABLE=notes-connections
API_BASE_URL=http://api:3000/api

SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
MAIL_TRANSPORT=log
MAIL_FROM=no-reply@notes.local

# CDK deploy settings
# Use a verified SES sender/domain for MAIL_FROM in AWS.
COGNITO_DOMAIN_PREFIX=
OAUTH_CALLBACK_URLS=
OAUTH_LOGOUT_URLS=
